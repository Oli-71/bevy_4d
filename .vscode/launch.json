    "version": "0.2.0",
    "configurations": [
    
        {
            "name": "Debug executable 'bevy_4d'",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "run",
                    "--bin=bevy_4d"
                ]
            },
            "env": {
                "RUST_BACKTRACE": "1"
            },
            "args": []
        },
        {
            "name": "Release executable 'bevy_4d' (release-fast)",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "run",
                    "--profile=release-fast",
                    "--bin=bevy_4d"
                ]
            },
            "env": {
                "RUST_BACKTRACE": "1"
            },
            "args": []
        },
        {
            "name": "Debug unit tests in executable 'bevy_4d'",
            "type": "lldb",
            "request": "launch",
            "cargo": {
                "args": [
                    "test",
                    "--bin=bevy_4d"
                ]
            },
            "env": {
                "RUST_BACKTRACE": "1"
            }
        }
    ]
}